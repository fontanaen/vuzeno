{
  "name": "vuzeno",
  "type": "module",
  "scripts": {
    "lint": "biome check ./apps/docs ./packages/registry",
    "lint:fix": "biome check --write ./apps/docs ./packages/registry",
    "lint:ci": "biome ci ./apps/docs ./packages/registry",
    "lint:check": "biome check ./apps/docs ./packages/registry",
    "lint:format": "biome format --write ./apps/docs ./packages/registry",
    "playground:dev": "bun run --filter=@vuzeno/playground dev",
    "docs:dev": "bun run --filter=@vuzeno/docs dev",
    "docs:preview": "bun run --filter=@vuzeno/docs preview",
    "docs:build": "bun run --filter=@vuzeno/docs build",
    "registry:build": "bun run --filter=@vuzeno/registry build"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "tools/*"
    ],
    "catalog": {
      "tailwind-merge": "^3.4.0",
      "tw-animate-css": "^1.4.0",
      "tailwindcss": "^4.1.11",
      "tailwindcss-animate": "^1.0.7",
      "@vueuse/core": "^14.1.0",
      "reka-ui": "2.8.2",
      "vue": "3.5.30",
      "@internationalized/date": "^3.10.1",
      "libphonenumber-js": "^1.12.34",
      "vitepress": "^1.6.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "shadcn-vue": "^2.4.3"
  }
}
