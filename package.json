{
  "name": "vuetella",
  "type": "module",
  "scripts": {
    "playground:dev": "bun run --filter=@vuetella/playground dev",
    "docs:dev": "bun run --filter=@vuetella/www dev",
    "docs:preview": "bun run --filter=@vuetella/www preview",
    "docs:build": "bun run --filter=@vuetella/www build",
    "registry:build": "bun run --filter=@vuetella/registry build"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "tools/*"
    ],
    "catalog": {
      "tailwind-merge": "^3.4.0",
      "tw-animate-css": "^1.4.0",
      "tailwindcss": "^4.1.11",
      "tailwindcss-animate": "^1.0.7",
      "@vueuse/core": "^14.1.0",
      "reka-ui": "^2.7.0",
      "vue": "^3.5.24",
      "@internationalized/date": "^3.10.1",
      "libphonenumber-js": "^1.12.34",
      "vitepress": "^1.6.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "shadcn-vue": "^2.4.3"
  }
}
